using System;

namespace ThinkSharp
{
    public class Program
    {
        static void Main(string[] args)
        {
            double count = 0.0;
            // original: while (count != 1.0)
            while (count - 1.0 < 1e-10)
            {
                count = count + 0.1;
                Console.Write("{0:R}", count);
                Console.ReadLine();
            }
        }
    }
}
